PORT=3001
NODE_ENV=development

# Optional if already set in repo root .env as VITE_SUPABASE_*:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Optional for local dev — public API routes use the anon key + RLS.
# Add for admin/server tasks that bypass RLS:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated origins for CORS (frontend URLs)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081

# Stripe — copy from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret — from `stripe listen --forward-to localhost:3001/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...
