PORT=3001
NODE_ENV=development

# Optional if already set in repo root .env as VITE_SUPABASE_*:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Required — Supabase Dashboard → Project Settings → API → service_role (never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated origins for CORS (frontend URLs)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
