# Database — in Docker the compose file injects DATABASE_URL automatically.
# For local dev without Docker, set this manually.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/startupa2z

# Postgres password — set this in Coolify env vars (used by docker-compose.yml)
POSTGRES_PASSWORD=change_this_strong_password

# JWT — generate a long random string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_long_random_secret

# SMTP (OTP emails) — for local dev use Mailpit: docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@startupa2z.org

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CORS — comma-separated origins (set to your production domain in Coolify)
CORS_ORIGINS=https://startupa2z.org,https://www.startupa2z.org

# Server (3001 for local dev to match Vite proxy; Docker overrides to 8080)
PORT=3001

# LinkedIn OAuth (optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://startupa2z.org/api/auth/oauth/linkedin/callback
